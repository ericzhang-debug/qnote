# 数据库配置
# SQLite:   DATABASE_PROVIDER=sqlite     DATABASE_URL="file:./prisma/dev.db"
# PostgreSQL: DATABASE_PROVIDER=postgresql DATABASE_URL="postgresql://user:pass@localhost:5432/qnote"
# MySQL:    DATABASE_PROVIDER=mysql      DATABASE_URL="mysql://user:pass@localhost:3306/qnote"
DATABASE_PROVIDER=sqlite
DATABASE_URL="file:./prisma/dev.db"

# JWT 密钥（生产环境请修改）
JWT_SECRET="your-jwt-secret-here"
