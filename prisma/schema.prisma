generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id          Int        @id @default(autoincrement())
  username    String     @unique
  password    String
  displayName String
  isAdmin     Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  qnotes      Qnote[]
  apiKeys     ApiKey[]
}

model Qnote {
  id        Int      @id @default(autoincrement())
  content   String
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  shareId   String   @unique
  isPublic  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Setting {
  id           Int      @id @default(autoincrement())
  siteName     String   @default("QNote")
  siteTitle    String   @default("QNote - 微语")
  siteSubtitle String   @default("记录生活中的每一句微语")
  showIcp      Boolean  @default(false)
  icpNumber    String   @default("")
  showGithub   Boolean  @default(false)
  githubUrl    String   @default("")
  updatedAt    DateTime @updatedAt
}

model ApiKey {
  id        Int      @id @default(autoincrement())
  name      String
  appKey    String   @unique
  appSecret String
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
